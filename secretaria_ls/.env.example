# ─────────────────────────────────────────────────────────────────
# Secretária LS Office — Configuração de Ambiente
# ─────────────────────────────────────────────────────────────────
# Copie este arquivo para .env e preencha os valores

# ── Provedor WhatsApp ─────────────────────────────────────────────
# Use "evolution" para Evolution API (self-hosted, recomendado)
# Use "twilio" para Twilio WhatsApp sandbox (cloud)
WA_PROVIDER=evolution

# ── Evolution API (Antigravity / self-hosted) ─────────────────────
# URL base da sua instância Evolution API
EVOLUTION_URL=http://localhost:8080

# Chave de API gerada no painel Evolution
EVOLUTION_API_KEY=sua_chave_aqui

# Nome da instância criada no Evolution (ex: ls-office)
EVOLUTION_INSTANCE=ls-office

# ── Twilio (alternativa cloud) ────────────────────────────────────
# Account SID do painel Twilio
TWILIO_SID=

# Auth Token do painel Twilio
TWILIO_TOKEN=

# Número Twilio WhatsApp (sandbox: whatsapp:+14155238886)
TWILIO_FROM=whatsapp:+14155238886

# ── Número padrão para alertas ────────────────────────────────────
# Número que receberá os relatórios automáticos (DDI + DDD + número)
# Ex: 5511999999999
DEFAULT_WA_NUMBER=55119XXXXXXXX
