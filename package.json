{
  "name": "ls-orcamento",
  "version": "1.0.0",
  "description": "Sistema de Orçamento LS",
  "main": "src/backend/server.ts",
  "scripts": {
    "dev:frontend": "vite",
    "dev:backend": "tsx watch src/backend/server.ts",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "build:frontend": "vite build",
    "build:backend": "tsc --project tsconfig.backend.json",
    "build": "npm run build:frontend && npm run build:backend"
  },
  "ts-node": {
    "compilerOptions": {
      "module": "CommonJS",
      "moduleResolution": "node"
    }
  },
  "dependencies": {
    "@prisma/client": "^5.10.2",
    "@tutao/oxmsg": "^0.0.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/uuid": "^10.0.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "fuzzball": "^2.2.3",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.344.0",
    "multer": "^2.1.0",
    "pdfjs-dist": "^5.6.205",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3",
    "recharts": "^3.7.0",
    "tailwind-merge": "^2.2.1",
