generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Tenant {
  id              String            @id @default(uuid())
  nome            String
  created_at      DateTime          @default(now())
  users           User[]
  contratantes    Contratante[]
  sites           Site[]
  catalogServices CatalogService[]
  budgetTemplates BudgetTemplate[]
  budgets         Budget[]
  auditLogs       AuditLog[]
  settings        TenantSettings?
  priceStats      PriceStats[]
  inflationIndexes InflationIndex[]
  bdiRules        BdiRules[]
  suppliers       Supplier[]
  priceBooks      PriceBook[]
  priceBookItems  PriceBookItem[]
  importBatches   ImportBatch[]
  secretariaTasks SecretariaTask[]
  secretariaConfig SecretariaConfig?
}

model TenantSettings {
  id                            String   @id @default(uuid())
  tenant_id                     String   @unique
  tenant                        Tenant   @relation(fields: [tenant_id], references: [id])
  aplicar_correcao_automatica   Boolean  @default(false)
  bdi_strategy                  String   @default("REGRA_FIXA") // REGRA_FIXA | FAIXA_SUGERIDA | HISTORICO
  default_inflation_rate_annual Float    @default(0.0)
  aplicar_bdi_automatico        Boolean  @default(false)
  updated_at                    DateTime @updatedAt
}

model PriceStats {
  id           String   @id @default(uuid())
  tenant_id    String
  tenant       Tenant   @relation(fields: [tenant_id], references: [id])
  item_key     String   // CatalogService id or descricao normalizada
  regiao       String
  count        Int
  min          Float
  max          Float
  mean         Float
  median       Float
  p25          Float
  p75          Float
  stddev       Float
  last_updated DateTime @default(now()) @updatedAt
}

model InflationIndex {
  id         String   @id @default(uuid())
  tenant_id  String
  tenant     Tenant   @relation(fields: [tenant_id], references: [id])
  index_name String   // IPCA, INCC, IGPM, MANUAL
  year_month String   // YYYY-MM
  factor     Float    // Ex: 1.0042
  created_at DateTime @default(now())
}

model BdiRules {
  id                  String   @id @default(uuid())
  tenant_id           String
  tenant              Tenant   @relation(fields: [tenant_id], references: [id])
  regiao              String
  categoria           String   // ENERGIA, CIVIL, RF, LOGISTICA, OUTROS
  bdi_default_percent Float
  bdi_min_percent     Float
  bdi_max_percent     Float
  active              Boolean  @default(true)
}

model User {
  id         String     @id @default(uuid())
  tenant_id  String
  tenant     Tenant     @relation(fields: [tenant_id], references: [id])
  nome       String
  email      String     @unique
  senha_hash String
  role       String     // ADMIN, COMERCIAL, OPERACOES
  ativo      Boolean    @default(true)
}

model Contratante {
  id              String    @id @default(uuid())
  tenant_id       String
  tenant          Tenant    @relation(fields: [tenant_id], references: [id])
  nome            String
  cnpj            String?
  contato_nome    String?
  contato_email   String?
  contato_telefone String?
  logo_url        String?
  budgets         Budget[]
}

model Site {
  id          String   @id @default(uuid())
  tenant_id   String
  tenant      Tenant   @relation(fields: [tenant_id], references: [id])
  id_site     String   // ex: RJCAM15_001
  endereco    String?
  cidade      String?
  uf          String?
  contrato    String?
  operadora   String?
  sharing     String?
  observacoes String?
  budgets     Budget[]
}

model CatalogService {
  id                   String  @id @default(uuid())
  tenant_id            String
  tenant               Tenant  @relation(fields: [tenant_id], references: [id])
  codigo               String  // ex: ENE-UR-INST
  titulo               String
  descricao_padrao     String?
  unidade_padrao       String  // vb, un, m, h, diaria
  valor_base           Float   @default(0)
  bdi_sugerido_percent Float   @default(0)
  categoria            String  // ENERGIA, CIVIL, RF, LOGISTICA, OUTROS
  ativo                Boolean @default(true)
  descricao_item_normalizada String?
  embedding_vector     String? // Armazenado como JSON string (vetor)
  origem_importacao_id String? 
}

model BudgetTemplate {
  id          String               @id @default(uuid())
  tenant_id   String
  tenant      Tenant               @relation(fields: [tenant_id], references: [id])
  nome        String
  descricao   String?
  ativo       Boolean              @default(true)
  items       BudgetTemplateItem[]
  budgets     Budget[]
}

model BudgetTemplateItem {
  id                     String         @id @default(uuid())
  template_id            String
  template               BudgetTemplate @relation(fields: [template_id], references: [id])
  bloco_id               String         // MOBILIZACAO, SERVICOS, INFRA
  codigo_item            String         // ex "01", "01.1"
  titulo                 String
  descricao              String?
  unidade                String
  quantidade_default     Float          @default(1)
  valor_unitario_default Float          @default(0)
  bdi_percent_default    Float          @default(0)
  ordem                  Int
}

model Budget {
  id             String          @id @default(uuid())
  tenant_id      String
  tenant         Tenant          @relation(fields: [tenant_id], references: [id])
  contratante_id String
  contratante    Contratante     @relation(fields: [contratante_id], references: [id])
  site_id        String
  site           Site            @relation(fields: [site_id], references: [id])
  supplier_id    String?
  supplier       Supplier?       @relation(fields: [supplier_id], references: [id])
  pricebook_id   String?
  pricebook      PriceBook?      @relation(fields: [pricebook_id], references: [id])
  template_id    String?
  template       BudgetTemplate? @relation(fields: [template_id], references: [id])
  regiao         String?
  pricing_mode   String          @default("SUPPLIER_BASE") // SUPPLIER_BASE | BEST_PRICE_REGION
  assunto        String?
  vigencia_dias  Int             @default(30)
  status         String          @default("RASCUNHO") // RASCUNHO, ENVIADO, APROVADO, REPROVADO, REVISAO
  versao_atual   Int             @default(1)
  created_by     String?
  created_at     DateTime        @default(now())
  updated_at     DateTime        @updatedAt
  versions       BudgetVersion[]
  items          BudgetItem[]
}

model BudgetVersion {
  id             String   @id @default(uuid())
  budget_id      String
  budget         Budget   @relation(fields: [budget_id], references: [id])
  versao         Int
  snapshot_json  String   // Backup completo da versão
  total_geral    Float
  criado_por     String?
  criado_em      DateTime @default(now())
  motivo_revisao String?
}

model BudgetItem {
  id             String  @id @default(uuid())
  budget_id      String
  budget         Budget  @relation(fields: [budget_id], references: [id])
  versao         Int
  bloco          String  // MOBILIZACAO, SERVICOS, INFRA
  codigo_item    String
  titulo         String
  descricao      String?
  unidade        String
  quantidade     Float
  valor_unitario Float
  bdi_percent    Float
  total_linha    Float   // Armazenado pra cache
  source_pricebook_item_id String?
  user_overridden Boolean @default(false)
  ativo          Boolean @default(true)
  ordem          Int
}

model AuditLog {
  id           String   @id @default(uuid())
  tenant_id    String
  tenant       Tenant   @relation(fields: [tenant_id], references: [id])
  entidade     String
  entidade_id  String
  acao         String
  antes_json   String?
  depois_json  String?
  user_id      String?
  created_at   DateTime @default(now())
}

model Supplier {
  id         String          @id @default(uuid())
  tenant_id  String
  tenant     Tenant          @relation(fields: [tenant_id], references: [id])
  nome       String
  cnpj       String?
  email      String?
  telefone   String?
  logo_url   String?
  ativo      Boolean         @default(true)
  created_at DateTime        @default(now())
  updated_at DateTime        @updatedAt
  priceBooks PriceBook[]
  budgets    Budget[]
  priceBookItems PriceBookItem[]
  importBatches  ImportBatch[]

  @@index([tenant_id, ativo])
}

model PriceBook {
  id                  String          @id @default(uuid())
  tenant_id           String
  tenant              Tenant          @relation(fields: [tenant_id], references: [id])
  supplier_id         String
  supplier            Supplier        @relation(fields: [supplier_id], references: [id])
  nome_lpu            String
  regiao              String
  data_inicio_vigencia DateTime?
  data_fim_vigencia   DateTime?
  moeda               String          @default("BRL")
  status              String          @default("ATIVA") // ATIVA | ARQUIVADA
  created_at          DateTime        @default(now())
  updated_at          DateTime        @updatedAt
  items               PriceBookItem[]
  importBatches       ImportBatch[]
  budgets             Budget[]

  @@index([tenant_id, supplier_id, regiao, status])
}

model ImportBatch {
  id                     String          @id @default(uuid())
  tenant_id              String
  tenant                 Tenant          @relation(fields: [tenant_id], references: [id])
  supplier_id            String?
  supplier               Supplier?       @relation(fields: [supplier_id], references: [id])
  pricebook_id           String?
  pricebook              PriceBook?      @relation(fields: [pricebook_id], references: [id])
  arquivo_nome           String
  arquivo_tipo           String
  status                 String          @default("RECEBIDO") // RECEBIDO | PROCESSANDO | AGUARDANDO_MAPEAMENTO | CONCLUIDO | ERRO
  total_linhas_lidas     Int             @default(0)
  total_linhas_importadas Int            @default(0)
  erros_json             String?
  mapping_json           String?
  preview_json           String?
  created_at             DateTime        @default(now())
  updated_at             DateTime        @updatedAt
  items                  PriceBookItem[]

  @@index([tenant_id, status, created_at])
}

model PriceBookItem {
  id                   String       @id @default(uuid())
  tenant_id            String
  tenant               Tenant       @relation(fields: [tenant_id], references: [id])
  pricebook_id         String
  pricebook            PriceBook    @relation(fields: [pricebook_id], references: [id])
  supplier_id          String
  supplier             Supplier     @relation(fields: [supplier_id], references: [id])
  regiao               String
  tipo_escopo          String       // SERVICO | INFRA
  subtipo              String?
  codigo_item          String?
  descricao            String
  descricao_normalizada String
  unidade              String
  valor_unitario       Float
  observacoes          String?
  detalhamento         String?
  data_referencia      DateTime?
  origem_importacao_id String?
  origem_importacao    ImportBatch? @relation(fields: [origem_importacao_id], references: [id])
  ativo                Boolean      @default(true)
  created_at           DateTime     @default(now())
  updated_at           DateTime     @updatedAt

  @@index([tenant_id, supplier_id, regiao, unidade, ativo])
  @@index([tenant_id, descricao_normalizada])
  @@index([pricebook_id, tipo_escopo, ativo])
}

model SecretariaTask {
  id          String   @id @default(uuid())
  tenant_id   String
  tenant      Tenant   @relation(fields: [tenant_id], references: [id])
  desc        String
  status      String   @default("pending") // pending | awaiting | done
  priority    String   @default("normal")  // normal | high | low
  client      String?  
  type        String?  
  date        String   // YYYY-MM-DD
  time        String?  // HH:MM
  resp        String?  
  deadline    String?  // YYYY-MM-DD
  note        String?  
  rescheduled Boolean  @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([tenant_id, date, status])
}

model SecretariaConfig {
  id                String   @id @default(uuid())
  tenant_id         String   @unique
  tenant            Tenant   @relation(fields: [tenant_id], references: [id])
  wa_number         String?
  daily_report_time String   @default("08:00")
  auto_reschedule   Boolean  @default(true)
  updated_at        DateTime @updatedAt
}
